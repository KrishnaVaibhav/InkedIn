#!/bin/sh
# InkedIn commit-msg hook — Conventional Commits.
# Enable once per clone:   git config core.hooksPath .githooks
# (CI re-checks every PR commit, so bypassing this only delays the red X.)

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

# merges, reverts and autosquash fixups are allowed through
case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

pattern='^(feat|fix|docs|test|refactor|perf|chore|build|ci|style|security)(\([a-z0-9._/-]+\))?!?: .{1,72}$'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  echo "✗ commit message does not follow Conventional Commits:" >&2
  echo "    $first_line" >&2
  echo "" >&2
  echo "  expected:  type(optional-scope): short imperative summary (≤72 chars)" >&2
  echo "  types:     feat fix docs test refactor perf chore build ci style security" >&2
  echo "  examples:  feat(ingest): add CB7 archive support" >&2
  echo "             fix(textlayer): keep bubble outlines intact when erasing" >&2
  exit 1
fi
exit 0
